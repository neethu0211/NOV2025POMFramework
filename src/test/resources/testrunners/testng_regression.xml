<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Open Cart Test  Regression Suite" verbose="3"  parallel="tests" thread-count="3">

<listeners>
		<listener class-name="com.aventstack.chaintest.plugins.ChainTestListener" />
		<listener class-name="com.opencart.qa.listeners.TestAllureListener" />
		<listener class-name="com.opencart.qa.listeners.AnnotationTransformer" />
	</listeners>
	
<!--test block -->

		
	 <test name="Login Page Test">
		<parameter name="browser" value="chrome"></parameter>
		<classes>
			<class name="com.opencart.qa.tests.LoginPageTest" /> <!--package name.class name-->
		</classes>
	</test> 
<test name="Home Page Test">
		<parameter name="browser" value="chrome"></parameter>
		<classes>
			<class name="com.opencart.qa.tests.HomePageTest" /> 
		</classes>
	</test>

<test name="Product Page Test">
		<parameter name="browser" value="chrome"></parameter>
		<classes>
		<class name="com.opencart.qa.tests.ProductInfoPageTest" /> 
		</classes>
	</test>

	<test name="Registration Page Test">
		<parameter name="browser" value="firefox"></parameter>
		<classes>
			<class name="com.opencart.qa.tests.RegisterPageTest" /> 
		</classes>
	</test> 
</suite>